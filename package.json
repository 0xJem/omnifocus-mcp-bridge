{
  "name": "omnifocus-mcp-bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Authenticated Streamable HTTP bridge for the omnifocus-mcp-enhanced stdio MCP server.",
  "bin": {
    "omnifocus-mcp-bridge": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/index.ts",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "start": "scripts/run-server.sh",
    "start:tailscale": "scripts/run-tailscale.sh",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "dotenv": "17.4.2",
    "omnifocus-mcp-enhanced": "1.6.10"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/node": "24.0.7",
    "tsx": "4.20.3",
    "typescript": "5.8.3",
    "vitest": "3.2.6"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@11.7.0"
}
